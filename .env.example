# Environment variables for Traefik

# External docker network name used by Traefik and services
TRAEFIK_NETWORK=traefik

# External port on the host to map to Traefik's internal 8080 (dashboard)
DASHBOARD_PORT_EXTERNAL=8080

# Email for Let's Encrypt registration and expiration notices
LETSENCRYPT_EMAIL=your-email@example.com

# Host path for certificate storage (mounted into container at /certs)
CERTS_DIR=./certs

# Hostname used for the dashboard router
# LOCAL DEVELOPMENT: use a .localhost domain (e.g., dashboard.docker.localhost)
#   - The docker-compose.override.yml file will automatically switch to HTTP (no ACME)
#   - Access via: http://dashboard.docker.localhost:8080 (with BasicAuth)
#
# PRODUCTION: use a real domain you control (e.g., dashboard.example.com)
#   - Delete or rename docker-compose.override.yml to enable HTTPS + Let's Encrypt
#   - Access via: https://dashboard.example.com (with BasicAuth)
DASHBOARD_HOST=dashboard.docker.localhost

# BasicAuth users (htpasswd-style): user:$apr1$HASH
# Generate a new hash with: htpasswd -nbB admin newpassword | cut -d: -f2
# Replace the default below with a secure hash or keep empty and set up a file provider.
BASICAUTH_USERS='admin:$apr1$8EVjn/nj$GiLUZqcbueTFeD23SuB6x0'
